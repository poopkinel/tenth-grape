// Meeple — Board Game Community Platform
// Prisma schema after pivot from matching app to community social network.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Users & Profiles ─────────────────────────────────────────────────────────

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String?
  googleId     String?  @unique
  name         String
  avatar       String?
  lat          Float?
  lng          Float?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  profile                Profile?
  games                  UserGame[]
  hostedSessions         Session[]
  sessionParticipants    SessionParticipant[]
  wonSessionGames        SessionGame[]        @relation("SessionGameWinner")
  authoredPosts          Post[]
  reactions              Reaction[]
  authoredComments       Comment[]
  sentFriendRequests     Friendship[]         @relation("FriendshipFrom")
  receivedFriendRequests Friendship[]         @relation("FriendshipTo")
  groupMemberships       GroupMember[]
  hostedEvents           Event[]
  eventAttendances       EventAttendee[]
  conversationsAsUser1   Conversation[]       @relation("ConvUser1")
  conversationsAsUser2   Conversation[]       @relation("ConvUser2")
  sentMessages           Message[]

  @@map("users")
}

model Profile {
  id              String          @id @default(cuid())
  userId          String          @unique
  bio             String?
  gamingFrequency GamingFrequency @default(CASUAL)
  languages       String[]
  maxTravelKm     Int             @default(25)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("profiles")
}

// ─── Games ────────────────────────────────────────────────────────────────────

model Game {
  bggId       Int      @id
  title       String
  description String?
  minPlayers  Int      @default(1)
  maxPlayers  Int      @default(4)
  minPlaytime Int?
  maxPlaytime Int?
  weight      Float    @default(2.5) // 1 (light) – 5 (heavy)
  thumbnail   String?
  categories  String[]
  createdAt   DateTime @default(now())

  userGames    UserGame[]
  sessionGames SessionGame[]
  postGames    PostGame[]

  @@map("games")
}

model UserGame {
  userId         String
  bggId          Int
  ownership      GameOwnership @default(OWN)
  personalRating Float?
  addedAt        DateTime      @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  game Game @relation(fields: [bggId], references: [bggId], onDelete: Cascade)

  @@id([userId, bggId])
  @@map("user_games")
}

// ─── Sessions (planned game nights + logged past plays) ───────────────────────

model Session {
  id           String        @id @default(cuid())
  hostId       String
  title        String
  scheduledAt  DateTime
  locationText String
  lat          Float
  lng          Float
  maxPlayers   Int           @default(4)
  description  String?
  status       SessionStatus @default(PLANNED)
  photos       String[]
  notes        String?
  completedAt  DateTime?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  host         User                 @relation(fields: [hostId], references: [id], onDelete: Cascade)
  games        SessionGame[]
  participants SessionParticipant[]
  post         Post?

  @@index([scheduledAt])
  @@map("sessions")
}

model SessionGame {
  sessionId String
  bggId     Int
  order     Int     @default(0) // play order within the session
  winnerId  String? // optional — user who won this particular game

  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  game    Game    @relation(fields: [bggId], references: [bggId], onDelete: Cascade)
  winner  User?   @relation("SessionGameWinner", fields: [winnerId], references: [id], onDelete: SetNull)

  @@id([sessionId, bggId])
  @@map("session_games")
}

model SessionParticipant {
  sessionId String
  userId    String
  status    SessionParticipantStatus @default(INVITED)
  position  Int?
  score     Int?
  won       Boolean                  @default(false)
  updatedAt DateTime                 @updatedAt

  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([sessionId, userId])
  @@map("session_participants")
}

// ─── Social feed: Posts, Reactions, Comments ──────────────────────────────────

model Post {
  id              String   @id @default(cuid())
  authorId        String
  type            PostType
  content         String?
  photos          String[]
  linkedSessionId String?  @unique // one auto-post per session
  linkedEventId   String?
  linkedGroupId   String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  author    User       @relation(fields: [authorId], references: [id], onDelete: Cascade)
  session   Session?   @relation(fields: [linkedSessionId], references: [id], onDelete: SetNull)
  event     Event?     @relation(fields: [linkedEventId], references: [id], onDelete: SetNull)
  group     Group?     @relation(fields: [linkedGroupId], references: [id], onDelete: Cascade)
  games     PostGame[]
  reactions Reaction[]
  comments  Comment[]

  @@index([authorId, createdAt])
  @@index([linkedGroupId, createdAt])
  @@index([createdAt])
  @@map("posts")
}

model PostGame {
  postId String
  bggId  Int
  order  Int    @default(0)

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  game Game @relation(fields: [bggId], references: [bggId], onDelete: Cascade)

  @@id([postId, bggId])
  @@map("post_games")
}

model Reaction {
  postId    String
  userId    String
  emoji     String
  createdAt DateTime @default(now())

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([postId, userId])
  @@map("reactions")
}

model Comment {
  id        String   @id @default(cuid())
  postId    String
  authorId  String
  content   String
  parentId  String?
  createdAt DateTime @default(now())

  post    Post      @relation(fields: [postId], references: [id], onDelete: Cascade)
  author  User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  parent  Comment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: SetNull)
  replies Comment[] @relation("CommentReplies")

  @@index([postId, createdAt])
  @@map("comments")
}

// ─── Friendships ──────────────────────────────────────────────────────────────

model Friendship {
  id         String           @id @default(cuid())
  fromUserId String
  toUserId   String
  status     FriendshipStatus @default(PENDING)
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt

  fromUser User @relation("FriendshipFrom", fields: [fromUserId], references: [id], onDelete: Cascade)
  toUser   User @relation("FriendshipTo", fields: [toUserId], references: [id], onDelete: Cascade)

  @@unique([fromUserId, toUserId])
  @@map("friendships")
}

// ─── Groups ───────────────────────────────────────────────────────────────────

model Group {
  id          String   @id @default(cuid())
  name        String
  description String?
  coverImage  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  members GroupMember[]
  posts   Post[]

  @@map("groups")
}

model GroupMember {
  groupId  String
  userId   String
  role     GroupRole @default(MEMBER)
  joinedAt DateTime  @default(now())

  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([groupId, userId])
  @@map("group_members")
}

// ─── Events ───────────────────────────────────────────────────────────────────

model Event {
  id              String    @id @default(cuid())
  title           String
  description     String?
  locationText    String
  lat             Float
  lng             Float
  startAt         DateTime
  endAt           DateTime?
  hostUserId      String?
  capacity        Int?
  coverImage      String?
  externalLink    String?
  /// Curated list of games being highlighted at this event. Not exhaustive —
  /// most events feature a handful of games out of a much larger library.
  featuredBggIds  Int[]     @default([])
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  host      User?           @relation(fields: [hostUserId], references: [id], onDelete: SetNull)
  attendees EventAttendee[]
  posts     Post[]

  @@index([startAt])
  @@map("events")
}

model EventAttendee {
  eventId   String
  userId    String
  status    EventAttendeeStatus @default(INTERESTED)
  updatedAt DateTime            @updatedAt

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([eventId, userId])
  @@map("event_attendees")
}

// ─── Conversations (renamed from Match, no mutual-like gate) ──────────────────

model Conversation {
  id        String   @id @default(cuid())
  userId1   String
  userId2   String
  createdAt DateTime @default(now())

  user1    User      @relation("ConvUser1", fields: [userId1], references: [id], onDelete: Cascade)
  user2    User      @relation("ConvUser2", fields: [userId2], references: [id], onDelete: Cascade)
  messages Message[]

  @@unique([userId1, userId2])
  @@map("conversations")
}

model Message {
  id             String    @id @default(cuid())
  conversationId String
  senderId       String
  content        String
  readAt         DateTime?
  createdAt      DateTime  @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User         @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@map("messages")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum GamingFrequency {
  CASUAL
  REGULAR
  HEAVY
}

enum GameOwnership {
  OWN
  WISHLIST
  WILLING
}

enum SessionStatus {
  PLANNED
  COMPLETED
}

enum SessionParticipantStatus {
  INVITED
  ACCEPTED
  DECLINED
}

enum PostType {
  PLAY_LOG
  TEXT
  PHOTO
  GAME_REVIEW
  EVENT_HIGHLIGHT
}

enum FriendshipStatus {
  PENDING
  ACCEPTED
  BLOCKED
}

enum GroupRole {
  OWNER
  MEMBER
}

enum EventAttendeeStatus {
  INTERESTED
  GOING
  ATTENDED
}
